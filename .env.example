# Render/PostgreSQL connection string. If set, this takes priority over DB_USER/DB_PASS/DB_IP/DB_PORT/DB_NAME.
# DATABASE_URL=postgresql://user:password@host:5432/tbgp

DB_USER=postgres
DB_PASS=password
DB_IP=127.0.0.1
DB_PORT=5432
DB_NAME=tbgp
SECRET_KEY=change_me_in_production

# Supabase Storage for Site Admin partner images (thumbnail, logo, gallery).
# Run migrations/supabase_partner_images_bucket.sql in your Supabase SQL Editor once.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
# SUPABASE_PARTNER_IMAGES_BUCKET=partner-images

# Member dashboard WhatsApp support (digits only, e.g. 639171234567)
# MEMBER_WHATSAPP_MEMBERSHIP=639171234567
# MEMBER_WHATSAPP_OTHER_MATTERS=639179876543

ADMIN_MEMBER_ID=
CLIENT_POOL_PERCENT=50
CONTRACTOR_POOL_PERCENT=25
ADMIN_ACCOUNT_PERCENT=25
MEMBER_EARNINGS_CAP_FIRST_PROJECT=15000000
MEMBER_EARNINGS_CAP_SECOND_PROJECT=10000000
MEMBER_EARNINGS_CAP_NTH_PROJECT=5000000
MEMBER_LIFETIME_EARNINGS_CAP=50000000
MEMBER_LIFETIME_PROJECT_CAP_AFTER_LIMIT=1000000
